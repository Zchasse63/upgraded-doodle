# =============================================================================
# tsg-cc-bridge — environment template
# =============================================================================
# Copy to .env.local (never commit). Supabase Edge Functions read these via
# Deno.env.get() at runtime. The supabase CLI maps .env values into the local
# function runtime via `supabase functions serve --env-file .env.local`.
# =============================================================================

# -------- PushPress -----------------------------------------------------------
# API key issued from PushPress dashboard. Shape: sk_xxxxxxxxxxxx:yyyyyyyyyyyy
# Sent verbatim as the `API-KEY` request header to api.pushpress.com.
PUSHPRESS_API_KEY=

# The PushPress company UUID for this tenant. Sent as `company-id` header.
# For the TSG sandbox account, this is the Sauna Guys company UUID; for
# production it will be Cigar City CrossFit's UUID.
PUSHPRESS_COMPANY_ID=

# Webhook signing secret. Returned by POST /webhooks (manageWebhooks.create)
# at subscription-creation time and not retrievable afterward. Used to verify
# the `webhook-signature` HMAC-SHA256 header on inbound payloads.
PUSHPRESS_WEBHOOK_SIGNING_SECRET=

# Server environment: "production" | "staging" | "development".
# Default: production. The staging URL is api.pushpressstage.com.
PUSHPRESS_SERVER=production

# -------- Glofox -------------------------------------------------------------
# All three headers are required — Glofox returns 200+success:false if any
# header is missing. Production: gf-api.aws.glofox.com/prod.
GLOFOX_API_KEY=
GLOFOX_API_TOKEN=
GLOFOX_BRANCH_ID=

# Optional override of the namespace path segment. Default value lives in
# the Meridian project at lib/glofox/client.ts; same value is expected here.
GLOFOX_NAMESPACE=

# -------- Supabase (this project, NOT Meridian) ------------------------------
# Create a NEW Supabase project for the bridge — do not reuse Meridian's
# (ptgeijftzfykjbiujvty). The middleware should be schema-isolated.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Service-role key — used by Edge Functions for writes that bypass RLS.
# Never expose this to the browser, never commit.
SUPABASE_SERVICE_ROLE_KEY=

# -------- Operational --------------------------------------------------------
# Pre-shared secret used by any cron / scheduled invocation of internal
# Edge Functions. Mirrors the pattern in Meridian.
CRON_SECRET=

# Slack webhook for ops alerts (overbookings, signature failures, etc).
# Optional in v1 — leave empty to disable Slack notifications.
SLACK_OPS_WEBHOOK_URL=
